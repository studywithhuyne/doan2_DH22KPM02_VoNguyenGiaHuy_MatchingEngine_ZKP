# .env.example
# Copy this file to .env and fill in real values.
# .env is git-ignored; this file is tracked as a reference.

# PostgreSQL connection string (local run outside Docker)
DATABASE_URL=postgres://admin:admin@localhost:5432/cex_db

# Backend logging
RUST_LOG=info

# Binance API settings (used server-side by backend live ticker proxy)
BINANCE_API_BASE_URL=https://api.binance.com/api/v3
BINANCE_API_KEY=
BINANCE_API_SECRET=
